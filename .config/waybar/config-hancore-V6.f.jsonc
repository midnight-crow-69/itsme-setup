{
  "exclusive": true,
  "layer": "top",
  "reload_style_on_change": true,
  "position": "top",
  "spacing": 4,
"height": 28,
"margin-top": 0,
  "width": 1440,
  "modules-left": [
    "group/left1", 
    "group/left2",
    "group/left3"
  ],
  "group/left1": {
    "orientation": "inherit",
    "modules": [
    "custom/scrow",
    "clock",
    "custom/idle-indicator",
    "custom/notification-silencing-indicator",
    "custom/voxtype",
    "idle_inhibitor",
    "custom/screenrecording-indicator",
    "custom/updatespacman",
    "custom/update"
  ]
  },
    "group/left2": {
    "orientation": "inherit",
    "modules": ["tray"]
  },
  "group/left3": {
    "orientation": "inherit",
    "modules": ["custom/scrow-theme", "custom/scrow-theme-set"]
  },


  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": ["group/right2", "group/right1"],

  "group/right1": {
    "orientation": "inherit",
    "modules": [
    "backlight", 
    "network",
    "bluetooth",
    "pulseaudio#output",
    "pulseaudio#input",
    "power-profiles-daemon",
    "memory",
    "cpu",
    "battery"
  ]
  },
    "group/right2": {
    "orientation": "inherit",
    "modules": ["mpris"]
  },

"custom/scrow-theme": {
  "exec": "omarchy-theme-current",
  "interval": 5,
  "format": "{}"
},

"custom/scrow-theme-set": {
  "on-click": "omarchy-theme-set Harbordark",
  "tooltip-format": "Back to your setted Themes",
  "interval": 5,
  "format": "¾░öÄ"
},
"custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "¾░Ź¼",
      "transcribing": "¾░ö¤"
    },
    "tooltip": true,
    "on-click-right": "omarchy-voxtype-config",
    "on-click": "omarchy-voxtype-model"
  },
      "custom/idle-indicator": {
    "on-click": "omarchy-toggle-idle",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
    "signal": 9,
    "return-type": "json"
  },
  "custom/notification-silencing-indicator": {
    "on-click": "omarchy-toggle-notification-silencing",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "signal": 10,
    "return-type": "json"
  },
