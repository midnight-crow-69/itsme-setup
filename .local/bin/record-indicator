#!/usr/bin/env python3
"""Camera-style blinking red dot recording indicator."""

import sys
import signal
import gi
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, GtkLayerShell, GLib
import math

visible = True


def main():
    global win
    win = Gtk.Window()
    GtkLayerShell.init_for_window(win)
    GtkLayerShell.set_layer(win, GtkLayerShell.Layer.OVERLAY)
    GtkLayerShell.set_namespace(win, "record-indicator")
    GtkLayerShell.set_exclusive_zone(win, -1)

    GtkLayerShell.set_anchor(win, GtkLayerShell.Edge.TOP, True)
    GtkLayerShell.set_anchor(win, GtkLayerShell.Edge.RIGHT, True)
    GtkLayerShell.set_margin(win, GtkLayerShell.Edge.TOP, 66)
    GtkLayerShell.set_margin(win, GtkLayerShell.Edge.RIGHT, 24)

    win.set_decorated(False)
    win.set_app_paintable(True)
    win.set_skip_taskbar_hint(True)
    win.set_skip_pager_hint(True)
    win.set_size_request(10, 10)

    screen = win.get_screen()
    visual = screen.get_rgba_visual()
    if visual:
        win.set_visual(visual)

    win.connect("draw", on_draw)
    win.connect("destroy", Gtk.main_quit)

    def blink(*args):
        global visible
        visible = not visible
        win.queue_draw()
        return True

    GLib.timeout_add(1000, blink)
    win.show_all()
    Gtk.main()


def on_draw(widget, cr):
    w, h = widget.get_allocated_width(), widget.get_allocated_height()
    cr.set_operator(1)
    cr.set_source_rgba(0, 0, 0, 0)
    cr.paint()

    if not visible:
        return

    cx, cy = w / 2.0, h / 2.0
    radius = min(w, h) / 2.0 - 1
    cr.set_source_rgba(0.95, 0.2, 0.2, 0.95)
    cr.arc(cx, cy, radius, 0, 2 * math.pi)
    cr.fill()


if __name__ == "__main__":
    signal.signal(signal.SIGTERM, lambda *_: Gtk.main_quit())
    main()
